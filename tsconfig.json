{
    "compilerOptions": {
		"target": "ES5",
		"module": "ES6",
		"moduleResolution": "node10",
		"lib": ["es2017", "es2016", "dom"],
		"allowUnreachableCode": true,
		"allowSyntheticDefaultImports": true,
		"pretty": true,
		"declaration": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"types": []
    },
    "exclude": [
        "./node_modules/**/*"
    ],
    "files": [
        "src/SearchBuilder.ts",
        "src/dataTables.searchBuilder.ts",
        "src/Criteria.ts",
        "src/Group.ts",
        "src/integrations/searchBuilder.bootstrap.ts",
        "src/integrations/searchBuilder.bootstrap4.ts",
        "src/integrations/searchBuilder.bootstrap5.ts",
        "src/integrations/searchBuilder.bulma.ts",
        "src/integrations/searchBuilder.dataTables.ts",
        "src/integrations/searchBuilder.foundation.ts",
        "src/integrations/searchBuilder.jqueryui.ts",
        "src/integrations/searchBuilder.semanticui.ts",
    ]
}